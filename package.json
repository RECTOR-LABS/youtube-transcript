{
  "name": "ytranscript",
  "version": "1.1.1",
  "description": "Fetch YouTube video transcripts via Innertube API with AI features.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ai": {
      "types": "./dist/ai.d.ts",
      "import": "./dist/ai.js"
    }
  },
  "bin": {
    "ytranscript": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "youtube",
    "transcript",
    "captions",
    "subtitles",
    "innertube",
    "cli",
    "ai",
    "summarize",
    "openrouter"
  ],
  "author": "RECTOR-LABS",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RECTOR-LABS/youtube-transcript.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/node": "^20.10.0"
  }
}
